{
  "name": "swish",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test",
    "db:migrate": "wrangler d1 migrations apply swish --local",
    "db:migrate:remote": "wrangler d1 migrations apply swish --remote",
    "deploy": "npm run build && wrangler pages deploy .svelte-kit/cloudflare"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.65.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.56.3",
    "vite": "^8.0.16",
    "wrangler": "^4.101.0"
  }
}
